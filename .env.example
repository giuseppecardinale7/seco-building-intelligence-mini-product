# Copy to .env and fill in your values
# cp .env.example .env

# ── Option A: Groq (free — recommended for quick start) ───────────────────────
# Get a free key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
# Default model (free, fast). Alternative: llama-3.3-70b-versatile (slower, smarter)
GROQ_MODEL=llama-3.1-8b-instant

# ── Option B: Anthropic Claude ────────────────────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Default model (fast, cheap). Upgrade: claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Option C: Google Gemini (free tier — requires AI Studio key) ──────────────
# Get a free key at https://aistudio.google.com/apikey  (key starts with AIza)
GOOGLE_API_KEY=AIza...
# Default model (free tier, fast).
GEMINI_MODEL=gemini-2.0-flash

# Only one provider key needs to be set. Priority: Anthropic → Groq → Gemini.
