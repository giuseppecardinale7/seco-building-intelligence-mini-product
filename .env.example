# Copy to .env and fill in your values
# cp .env.example .env

# ── Option A: Anthropic Claude (recommended) ──────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Default model (fast, cheap). Upgrade: claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Option B: Google Gemini (free tier available) ─────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# The app auto-selects Gemini if GOOGLE_API_KEY is set and ANTHROPIC_API_KEY is not.
GOOGLE_API_KEY=AIza...
# Default model (free tier, fast). Alternatives: gemini-1.5-pro, gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash

# Only one provider key needs to be set. Anthropic takes priority if both are present.
